{
  "manifest_version": 3,
  "name": "AI Job Assistant",
  "version": "2.0.6",
  "description": "AI-powered job matcher for LinkedIn and Naukri. Auto-evaluates jobs against your resume. Free to use.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.naukri.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*.railway.app/*"
  ],
  "action": {
    "default_title": "AI Job Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["scripts/content_linkedin.js"]
    },
    {
      "matches": ["*://*.naukri.com/*"],
      "js": ["scripts/content_naukri.js"]
    }
  ]
}
